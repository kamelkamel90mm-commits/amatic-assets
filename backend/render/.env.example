# Required
MEGANODES_API_TOKEN=put_meganodes_main_api_token_here

# CORS origins separated by comma
ALLOWED_ORIGINS=https://poseidon-casino-kamel.surge.sh,http://localhost:8080,http://localhost:3000

# MegaNodes
MEGANODES_API_BASE=https://api-prd-v2.meganodes.net
DEFAULT_LANG=en
DEFAULT_RETURN_URL=https://poseidon-casino-kamel.surge.sh/casino.html

# Users
# false = allow anonymous browser IDs and auto-create MegaNodes users
# true = require Supabase Authorization bearer token
REQUIRE_AUTH=false
AUTO_CREATE_USERS=true

# Optional Supabase login verification. Set these if you want REQUIRE_AUTH=true.
SUPABASE_URL=https://ynsjeihnqixqvkyzzpsz.supabase.co
SUPABASE_ANON_KEY=

# Optional. WARNING: deposit debits agent balance. Keep 0 unless you are sure.
MEGANODES_INITIAL_DEPOSIT=0

# Render can use /tmp; if you add a persistent disk, set DATA_DIR=/var/data
DATA_DIR=/tmp/poseidon-meganodes
